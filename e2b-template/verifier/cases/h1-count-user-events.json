[
  {
    "name": "typical-3-users-5-events",
    "inputs": {
      "events": [
        { "user_id": "u1", "value": 10 },
        { "user_id": "u2", "value": 20 },
        { "user_id": "u1", "value": 5 },
        { "user_id": "u3", "value": 7 },
        { "user_id": "u2", "value": 3 }
      ]
    },
    "expected": { "unique_users": 3, "total_events": 5, "total_value": 45 }
  },
  {
    "name": "all-same-user",
    "inputs": {
      "events": [
        { "user_id": "u1", "value": 10 },
        { "user_id": "u1", "value": 20 },
        { "user_id": "u1", "value": 5 }
      ]
    },
    "expected": { "unique_users": 1, "total_events": 3, "total_value": 35 }
  },
  {
    "name": "all-distinct",
    "inputs": {
      "events": [
        { "user_id": "a", "value": 1 },
        { "user_id": "b", "value": 2 },
        { "user_id": "c", "value": 3 }
      ]
    },
    "expected": { "unique_users": 3, "total_events": 3, "total_value": 6 }
  },
  {
    "name": "empty",
    "inputs": { "events": [] },
    "expected": { "unique_users": 0, "total_events": 0, "total_value": 0 }
  },
  {
    "name": "with-negatives",
    "inputs": {
      "events": [
        { "user_id": "u1", "value": 100 },
        { "user_id": "u2", "value": -30 },
        { "user_id": "u1", "value": -50 }
      ]
    },
    "expected": { "unique_users": 2, "total_events": 3, "total_value": 20 }
  }
]
